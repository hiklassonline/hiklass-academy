NODE_ENV=development
# Local only. Many hosts (e.g. Hostinger's Node.js proxy) inject the runtime
# port automatically - do not set PORT in that host's environment variables.
# PORT=5000
# Used to build links inside emails (e.g. password reset) and for the CORS
# allow-list. For local development this can be left as the production URL -
# http://localhost:5173 and http://localhost:3000 are always allowed for CORS
# regardless of this value (see defaultOrigins in index.js). Set it explicitly
# to http://localhost:5173 only if you want locally-generated email links to
# point at your local dev frontend instead of production.
CLIENT_URL=https://hiklassacademy.com
API_BASE_URL=https://hiklassacademy.com
# Local backend URL, used for reference/tooling. The server itself reads PORT.
SERVER_URL=http://localhost:5000

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@hiklassacademy.com
SMTP_PASS=your_password_here
SMTP_PASS_BASE64=
SMTP_FROM="HIKLASS Academy <info@hiklassacademy.com>"
SMTP_TIMEOUT_MS=30000

ADMIN_EMAIL=info@hiklassacademy.com
ADMIN_LOGIN_EMAIL=info@hiklassacademy.com
BUSINESS_NAME=HIKLASS Academy
# Used to sign student portal login sessions. Required in production.
JWT_SECRET=change_this_secret
ADMIN_TOKEN=change_this_admin_dashboard_token
ADMIN_PASSWORD=change_this_admin_password
API_RATE_LIMIT_MAX=600
ADMIN_LOGIN_RATE_LIMIT_MAX=20
# OAuth client ID from Google Cloud Console, used to verify Google sign-in/sign-up tokens.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
UPLOAD_DIR=uploads
# Optional: point persisted JSON data (orders, enrollments, etc.) outside the
# deployed app folder so it survives redeploys. Absolute path, or relative to
# the project root. Defaults to "storage" (the old hardcoded location).
DATA_DIR=storage
SMARTSUPP_KEY=your_smartsupp_key
