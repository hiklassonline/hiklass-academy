NODE_ENV=development
PORT=5000
CLIENT_URL=https://hiklassacademy.com
API_BASE_URL=https://hiklassacademy.com

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@hiklassacademy.com
SMTP_PASS=your_password_here
SMTP_PASS_BASE64=
SMTP_FROM="HIKLASS Academy <info@hiklassacademy.com>"
SMTP_TIMEOUT_MS=30000

ADMIN_EMAIL=info@hiklassacademy.com
ADMIN_LOGIN_EMAIL=info@hiklassacademy.com
BUSINESS_NAME=HIKLASS Academy
# Used to sign student portal login sessions. Required in production.
JWT_SECRET=change_this_secret
ADMIN_TOKEN=change_this_admin_dashboard_token
ADMIN_PASSWORD=change_this_admin_password
# OAuth client ID from Google Cloud Console, used to verify Google sign-in/sign-up tokens.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
UPLOAD_DIR=uploads
# Optional: point persisted JSON data (orders, enrollments, etc.) outside the
# deployed app folder so it survives redeploys. Absolute path, or relative to
# the project root. Defaults to "storage" (the old hardcoded location).
DATA_DIR=storage
SMARTSUPP_KEY=your_smartsupp_key
